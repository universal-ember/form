{
  "extends": "@ember/app-tsconfig",
  "compilerOptions": {
    "allowJs": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "types": [
      "ember-source/types",
      "@embroider/core/virtual",
      "vite/client",
      "@glint/ember-tsc/types",
      "ember-data/unstable-preview-types",
      "@ember-data/model/unstable-preview-types",
      "@ember-data/store/unstable-preview-types"
    ],
    "paths": {
      "test-app/tests/*": ["./tests/*"],
      "test-app/*": ["./app/*"],
      // The workspace still contains @glimmer/component v1 (docs-app), so
      // pnpm's fallback lookup can hand glint's `declare module` augmentation
      // a different copy than the app uses. Pin one identity for this project.
      "@glimmer/component": ["./node_modules/@glimmer/component"],
      "@glimmer/component/*": ["./node_modules/@glimmer/component/*"]
    }
  },
  "include": ["app/**/*", "tests/**/*"]
}
