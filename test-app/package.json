{
  "name": "test-app",
  "version": "0.0.0",
  "private": true,
  "description": "Test app for the @universal-ember/form packages",
  "repository": "",
  "license": "MIT",
  "author": "",
  "type": "module",
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  },
  "scripts": {
    "build": "vite build",
    "build:test": "EMBER_ENV=test NODE_ENV=development vite build --mode development",
    "lint": "concurrently 'npm:lint:*(!fix)' --names 'lint:'",
    "lint:fix": "concurrently 'npm:lint:*:fix' --names 'fix:'",
    "lint:hbs": "ember-template-lint . --no-error-on-unmatched-pattern",
    "lint:hbs:fix": "ember-template-lint . --fix --no-error-on-unmatched-pattern",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:prettier": "prettier -c .",
    "lint:prettier:fix": "prettier -w .",
    "lint:types": "ember-tsc --noEmit",
    "start": "vite",
    "test": "pnpm build:test && pnpm test:ci",
    "test:ci": "testem ci --port 0",
    "typecheck": "pnpm tsc -v; pnpm ember-tsc --version; pnpm lint:types"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-runtime": "^7.29.7",
    "@babel/plugin-transform-typescript": "^7.29.7",
    "@babel/runtime": "^7.29.7",
    "@ember-data/model": "^5.8.2",
    "@ember-data/store": "^5.8.2",
    "@ember/app-tsconfig": "^2.0.0",
    "@ember/test-helpers": "^5.4.3",
    "@ember/test-waiters": "^4.1.2",
    "@embroider/core": "^4.6.2",
    "@embroider/legacy-inspector-support": "^0.1.3",
    "@embroider/macros": "^1.20.5",
    "@embroider/router": "^3.0.6",
    "@glimmer/component": "^2.1.1",
    "@glint/ember-tsc": "^1.8.12",
    "@glint/template": "^1.7.8",
    "@glint/tsserver-plugin": "^2.5.18",
    "@nullvoxpopuli/ember-vite": "^1.1.0",
    "@nullvoxpopuli/eslint-configs": "^6.0.0",
    "@rollup/plugin-babel": "^7.1.0",
    "@types/qunit": "^2.19.14",
    "@types/sinon": "^17.0.0",
    "@universal-ember/form": "workspace:*",
    "@universal-ember/form-changeset": "workspace:*",
    "@universal-ember/form-yup": "workspace:*",
    "@warp-drive/build-config": "^5.8.2",
    "axe-core": "^4.12.1",
    "babel-plugin-ember-template-compilation": "^4.0.0",
    "concurrently": "^9.0.0",
    "decorator-transforms": "^2.4.0",
    "ember-a11y-testing": "^8.0.1",
    "ember-changeset": "^5.0.0",
    "ember-data": "^5.3.0",
    "ember-qunit": "^9.1.0",
    "ember-source": "^7.0.0",
    "ember-strict-application-resolver": "^0.1.1",
    "ember-template-lint": "^5.2.0",
    "eslint": "^9.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-ember-template-tag": "^2.1.3",
    "qunit": "^2.26.0",
    "qunit-dom": "^3.5.0",
    "qunit-theme-ember": "^1.0.0",
    "sinon": "^20.0.0",
    "testem": "^3.17.0",
    "typescript": "~6.0.0",
    "validated-changeset": "^1.3.4",
    "vite": "^8.1.5",
    "yup": "^1.0.0"
  },
  "dependenciesMeta": {
    "@universal-ember/form": {
      "injected": true
    },
    "@universal-ember/form-changeset": {
      "injected": true
    },
    "@universal-ember/form-yup": {
      "injected": true
    }
  },
  "engines": {
    "node": ">= 24"
  }
}
