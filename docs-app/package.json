{
  "name": "docs-app",
  "version": "0.0.0",
  "private": true,
  "description": "Documentation app for @universal-ember/form",
  "repository": "",
  "license": "MIT",
  "author": "",
  "type": "module",
  "imports": {
    "#src/*": "./src/*",
    "#config": "./src/config.ts",
    "#components/*": "./src/components/*"
  },
  "exports": {
    "./*": "./src/*"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "type": "app",
    "version": 2
  },
  "scripts": {
    "build": "vite build",
    "lint": "concurrently 'npm:lint:*(!fix)' --names 'lint:'",
    "lint:fix": "concurrently 'npm:lint:*:fix' --names 'fix:'",
    "lint:hbs": "ember-template-lint . --no-error-on-unmatched-pattern",
    "lint:hbs:fix": "ember-template-lint . --fix --no-error-on-unmatched-pattern",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:prettier": "prettier -c .",
    "lint:prettier:fix": "prettier -w .",
    "lint:types": "ember-tsc --noEmit",
    "start": "vite"
  },
  "dependencies": {
    "@ember/test-waiters": "^4.1.1",
    "@embroider/router": "^3.0.6",
    "@shikijs/rehype": "^3.22.0",
    "@universal-ember/docs-support": "^0.9.11",
    "@universal-ember/form": "workspace:*",
    "@universal-ember/form-changeset": "workspace:*",
    "@universal-ember/form-yup": "workspace:*",
    "content-tag": "^4.1.0",
    "dompurify": "^3.3.1",
    "ember-changeset": "^5.0.0",
    "ember-modifier": "^4.3.0",
    "ember-page-title": "^9.0.3",
    "ember-primitives": "^0.53.0",
    "ember-repl": "^8.0.2",
    "ember-resources": "^7.0.7",
    "ember-strict-application-resolver": "^0.1.1",
    "kolay": "^5.1.3",
    "reactiveweb": "^1.9.1",
    "shiki": "^3.22.0",
    "tracked-built-ins": "^4.1.0",
    "validated-changeset": "^1.3.4",
    "yup": "^1.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/plugin-transform-typescript": "^7.29.7",
    "@babel/runtime": "^7.29.7",
    "@ember/app-tsconfig": "^2.0.0",
    "@embroider/core": "^4.4.3",
    "@embroider/macros": "^1.19.7",
    "@embroider/vite": "^1.5.2",
    "@glimmer/component": "^2.0.0",
    "@glint/ember-tsc": "^1.8.12",
    "@glint/template": "^1.7.8",
    "@glint/tsserver-plugin": "^2.5.18",
    "@nullvoxpopuli/eslint-configs": "^6.0.0",
    "@rollup/plugin-babel": "^7.1.0",
    "@warp-drive/build-config": "^5.8.2",
    "babel-plugin-ember-template-compilation": "^4.0.0",
    "concurrently": "^9.2.1",
    "decorator-transforms": "^2.3.1",
    "ember-source": "^7.1.0",
    "ember-template-lint": "^5.2.0",
    "eslint": "^9.22.0",
    "prettier": "^3.8.1",
    "prettier-plugin-ember-template-tag": "^2.1.3",
    "typescript": "~6.0.0",
    "vite": "^8.1.5"
  },
  "dependenciesMeta": {
    "@universal-ember/form": {
      "injected": true
    },
    "@universal-ember/form-changeset": {
      "injected": true
    },
    "@universal-ember/form-yup": {
      "injected": true
    }
  },
  "engines": {
    "node": ">= 24"
  }
}
