{
  "extends": "@ember/app-tsconfig",
  "compilerOptions": {
    "types": [
      "ember-source/types",
      "vite/client",
      "kolay/virtual",
      "@embroider/core/virtual",
      "@glint/ember-tsc/types"
    ],
    "paths": {
      "docs-app/tests/*": ["./tests/*"],
      "docs-app/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*"]
}
